---
// src/components/NewsBanner.astro
// Announcement banner for workshops and news
---

<div class="news-banner">
  <div class="banner-link banner-static">
    <span class="banner-badge">New</span>
    <span class="banner-text">
      <strong>May 28, 2026</strong> &middot; Project page is now live!
    </span>
  </div>
</div>

<style>
  .news-banner {
    background: linear-gradient(135deg, #1F5E36 0%, #2D8F47 100%);
    padding: 0;
    position: relative;
    z-index: 9;
  }

  .banner-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.65rem 1rem;
    color: white;
    text-decoration: none;
    font-size: 0.95rem;
    transition: background 0.2s ease;
  }

  .banner-link:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .banner-badge {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
    padding: 0.2rem 0.6rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .banner-text {
    color: rgba(255, 255, 255, 0.95);
  }

  .banner-text strong {
    color: #fff;
    font-weight: 600;
  }

  .banner-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: #fff;
    font-weight: 600;
    padding-left: 0.75rem;
    border-left: 1px solid rgba(255, 255, 255, 0.3);
  }

  .arrow-icon {
    width: 16px;
    height: 16px;
    transition: transform 0.2s ease;
  }

  .banner-link:hover .arrow-icon {
    transform: translateX(3px);
  }

  @media (max-width: 768px) {
    .banner-link {
      flex-wrap: wrap;
      gap: 0.5rem;
      padding: 0.75rem 1rem;
      text-align: center;
    }

    .banner-badge {
      order: -1;
    }

    .banner-cta {
      border-left: none;
      padding-left: 0;
      width: 100%;
      justify-content: center;
      margin-top: 0.25rem;
    }
  }
</style>
